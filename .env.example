APP_VERSION=dev
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wakaya-erp
LOG_LEVEL=info
PORT=3000
AUTH_DEV_BYPASS=true
# Solo usar estos fallbacks si estas diagnosticando sin PostgreSQL.
# En el flujo operativo del MVP la persistencia objetivo es PostgreSQL.
# WAKAYA_RESERVATIONS_DB_PATH=.data/wakaya-reservations.snapshot.json
# WAKAYA_BACKOFFICE_AUTH_PATH=.data/wakaya-backoffice-auth.snapshot.json
# WAKAYA_MEDIA_STORAGE_PATH=.data/wakaya-media
BACKOFFICE_BOOTSTRAP_EMAIL=admin@wakaya.local
BACKOFFICE_BOOTSTRAP_NAME=Backoffice Admin
BACKOFFICE_BOOTSTRAP_PASSWORD=wakaya-admin-123
BACKOFFICE_BOOTSTRAP_ROLES=admin
BACKOFFICE_SESSION_TTL_HOURS=12
OIDC_ISSUER=https://iam.example.com/realms/wakaya
OIDC_JWKS_URL=https://iam.example.com/realms/wakaya/protocol/openid-connect/certs
OIDC_AUDIENCE=wakaya-erp-web
OIDC_ROLES_CLAIM=realm_access.roles
BOOKING_API_BASE_URL=https://distribution-xml.booking.com/2.4
BOOKING_API_USERNAME=
BOOKING_API_PASSWORD=
BOOKING_POLL_INTERVAL_SECONDS=20
BOOKING_RECOVERY_INTERVAL_MINUTES=30
BOOKING_MESSAGES_ENABLED=false
BOOKING_ARI_ENABLED=false
OTA_JOB_BASE_URL=http://127.0.0.1:3212
OTA_JOB_TOKEN=

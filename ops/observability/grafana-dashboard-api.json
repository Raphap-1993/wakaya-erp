{
  "title": "Wakaya ERP API - Overview",
  "uid": "wakaya-erp-api-overview",
  "schemaVersion": 38,
  "version": 1,
  "timezone": "",
  "refresh": "30s",
  "tags": ["wakaya-erp", "api", "slo"],
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "query",
        "query": "label_values(http_requests_total, env)",
        "datasource": "Prometheus",
        "current": { "text": "prod", "value": "prod" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Disponibilidad 30d",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "slo:availability:ratio_rate30d",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.995 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "RPS por codigo",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum by (code) (rate(http_requests_total{env=\"$env\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{code}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latencia p50/p95/p99",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{env=\"$env\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{env=\"$env\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{env=\"$env\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Tasa de errores 5xx",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{env=\"$env\",code=~\"5..\"}[5m])) / sum(rate(http_requests_total{env=\"$env\"}[5m]))",
          "refId": "A",
          "legendFormat": "error_rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Saturacion - pods y CPU",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"wakaya-erp-$env\",pod=~\"wakaya-erp-api.*\"}[5m]))",
          "refId": "A",
          "legendFormat": "cpu cores"
        },
        {
          "expr": "count(kube_pod_status_ready{namespace=~\"wakaya-erp-$env\",condition=\"true\",pod=~\"wakaya-erp-api.*\"})",
          "refId": "B",
          "legendFormat": "pods ready"
        }
      ]
    }
  ]
}

{
  "consumer": {
    "name": "wakaya-erp-web"
  },
  "interactions": [
    {
      "description": "GET /api/reservations?status=open",
      "providerStates": [
        {
          "name": "there are active reservations"
        }
      ],
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/api/reservations",
        "query": {
          "status": [
            "open"
          ]
        }
      },
      "response": {
        "body": {
          "items": [
            {
              "id": "e2490de5-5bd3-43d5-b7c4-526e33f71304",
              "status": "open",
              "updatedAt": "2026-06-03T10:15:30.000Z"
            }
          ],
          "page": 1,
          "pageSize": 20,
          "total": 42
        },
        "generators": {
          "body": {
            "$.items[*].id": {
              "type": "Uuid"
            }
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.items": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.items[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            },
            "$.items[*].status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].updatedAt": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss.SSSX",
                  "match": "datetime"
                }
              ]
            },
            "$.page": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.pageSize": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.total": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.3.1"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "wakaya-erp-api"
  }
}